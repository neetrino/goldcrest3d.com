// Goldcrest 3D — Neon PostgreSQL
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  // Next.js + pnpm: stable path so the bundler always loads the client built from the current schema.
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ——— Auth.js (admin panel) ———
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  username      String?   @unique // Login (email or username)
  name          String?
  password      String?   // bcrypt hash; Credentials provider for admin
  emailVerified DateTime?
  image         String?
  role          String?   @default("ADMIN") // ADMIN for admin panel access
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ——— App models ———
model Lead {
  id         String   @id @default(cuid())
  fullName   String
  email      String
  message    String   @db.Text
  attachmentKeys String[] // R2 keys for quote form uploads
  /// Set when an admin has opened the lead detail; null = unread in inbox.
  readAt     DateTime?
  /// Set after the first successful admin reply email; blocks further replies from the UI.
  repliedAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([readAt])
}

model Order {
  id            String   @id @default(cuid())
  token         String   @unique // public link token for client payment page
  clientName    String
  clientEmail   String
  productTitle  String
  productImageKey String? // R2 key
  priceCents    Int      // order total in whole major units (legacy column name)
  paymentLinkMode String @default("FULL_ONLY") // FULL_ONLY | SPLIT_ENABLED (admin-controlled link options)
  paymentType   String   // FULL | SPLIT | UNSET (UNSET until client chooses)
  paidCents     Int      @default(0) // paid total in whole major units (Stripe minor ÷ factor)
  status        String   @default("PENDING") // PENDING | PAYMENT_PROCESSING | PAID
  /// Set when the payment link email was successfully sent (admin action).
  paymentLinkSentAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

/// Site-wide managed images (R2 object keys; public URL via R2_PUBLIC_URL).
/// Neon-ում սյուների անունները՝ sectionKey / slotId (ոչ թե groupKey / slotKey)։
model SiteMediaItem {
  id             String   @id @default(cuid())
  sectionKey     String
  /// Modeling slot id (e.g. hip_hop) or UUID for gallery rows — DB-ում GLOBAL UNIQUE։
  slotId         String   @unique
  sortOrder      Int      @default(0)
  r2ObjectKey    String?
  /// Modeling Specialization only — separate mobile asset; optional when desktop is set (falls back to desktop URL on site).
  r2ObjectKeyMobile String?
  /// Modeling Specialization only — tablet-only asset; isolated from desktop/mobile at runtime (no URL fallback).
  r2ObjectKeyTablet String?
  legacySrc      String?
  alt            String?
  layoutMeta     Json?
  publicLabelKey String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([sectionKey, sortOrder])
}

/// Editable hero (power banner) title + body per landing slide — managed in Admin → Media Manager.
model PowerBannerCopy {
  bannerKey String
  viewport  String
  title     String   @db.Text
  body      String   @db.Text
  /// Per-viewport hero: vertical offset (px) for the title line(s).
  titleOffsetY Int @default(0)
  /// Per-viewport hero: vertical offset (px) for the description line(s).
  bodyOffsetY  Int @default(0)
  /// Per-viewport hero: vertical offset (px) for the Get a Quote CTA.
  ctaOffsetY  Int    @default(0)
  /// Horizontal offset (px) for the title — used by tablet layout (desktop/mobile rows typically 0).
  titleOffsetX Int    @default(0)
  /// Horizontal offset (px) for the description — used by tablet layout.
  bodyOffsetX  Int    @default(0)
  /// Horizontal offset (px) for the Get a Quote CTA — used by tablet layout.
  ctaOffsetX   Int    @default(0)
  updatedAt DateTime @updatedAt

  @@id([bannerKey, viewport])
}

/// Editable text content for each Modeling Specialization card.
/// Stores desktop/mobile title and body separately. Bodies are newline-separated lines.
model ModelingSpecializationCopy {
  slotKey               String   @id
  titleDesktop          String?  @db.Text
  titleMobile           String?  @db.Text
  bodyDesktop           String?  @db.Text
  bodyMobile            String?  @db.Text
  /// Copy vertical offsets (ints): CSS translateY percentage, typically -1500…1500.
  titleDesktopOffsetY   Int      @default(0)
  titleMobileOffsetY    Int      @default(0)
  bodyDesktopOffsetY    Int      @default(0)
  bodyMobileOffsetY     Int      @default(0)
  /// Desktop title horizontal shift (translateX % of text box; same clamp range as tablet X/Y).
  titleDesktopOffsetX   Int      @default(0)
  /// Desktop body horizontal shift (translateX % of text box).
  bodyDesktopOffsetX    Int      @default(0)
  /// Mobile title horizontal shift (translateX % of text box; same clamp as desktop/tablet X).
  titleMobileOffsetX    Int      @default(0)
  /// Mobile body horizontal shift (translateX % of text box).
  bodyMobileOffsetX     Int      @default(0)
  titleTablet           String?  @db.Text
  bodyTablet            String?  @db.Text
  /// Tablet vertical shifts (translateY % of text box; app clamp typically -10000…10000).
  titleTabletOffsetY    Int      @default(0)
  bodyTabletOffsetY     Int      @default(0)
  /// Tablet title horizontal shift (translateX % of text box; app clamp typically -10000…10000).
  titleTabletOffsetX    Int      @default(0)
  /// Tablet body horizontal shift (translateX % of text box; same clamp as titleTabletOffsetX).
  bodyTabletOffsetX     Int      @default(0)
  /// Optional emphasized fragment for slots that require highlighted wording.
  desktopLine1Emphasis  String?  @db.Text
  tabletLine1Emphasis   String?  @db.Text
  /// Mobile title size (px, viewport below md) on landing + admin preview; scales with section --ms/--mt.
  mobilePreviewTitleFontPx Int @default(16)
  /// Mobile description size (px, viewport below md) on landing + admin preview; scales with section --ms/--mt.
  mobilePreviewBodyFontPx  Int @default(14)
  updatedAt             DateTime @updatedAt
}

/// Editable text content for Manufacturing Intelligence section (key-value).
model ManufacturingIntelligenceCopy {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

/// Editable text content for Manufacturing Intelligence mobile section (key-value).
model ManufacturingIntelligenceMobileCopy {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

/// Editable text content for Founder & Lead CAD Engineer desktop section.
model FounderSectionCopy {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

/// Editable text content for Founder & Lead CAD Engineer mobile section.
model FounderSectionMobileCopy {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

/// Editable text content for Our Engineering Process section (shared desktop/mobile).
model EngineeringProcessCopy {
  stepKey     String   @id
  title       String   @db.Text
  description String   @db.Text
  updatedAt   DateTime @updatedAt
}

/// Editable footer social links for the "Follow" block.
model FooterSocialLink {
  key       String   @id
  url       String?  @db.Text
  updatedAt DateTime @updatedAt
}
