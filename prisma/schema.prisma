// Goldcrest 3D — Neon PostgreSQL
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  // Next.js + pnpm: stable path so the bundler always loads the client built from the current schema.
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ——— Auth.js (admin panel) ———
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  username      String?   @unique // Login (email or username)
  name          String?
  password      String?   // bcrypt hash; Credentials provider for admin
  emailVerified DateTime?
  image         String?
  role          String?   @default("ADMIN") // ADMIN for admin panel access
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ——— App models ———
model Lead {
  id         String   @id @default(cuid())
  fullName   String
  email      String
  message    String   @db.Text
  attachmentKeys String[] // R2 keys for quote form uploads
  /// Set when an admin has opened the lead detail; null = unread in inbox.
  readAt     DateTime?
  /// Set after the first successful admin reply email; blocks further replies from the UI.
  repliedAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([readAt])
}

model Order {
  id            String   @id @default(cuid())
  token         String   @unique // public link token for client payment page
  clientName    String
  clientEmail   String
  productTitle  String
  productImageKey String? // R2 key
  priceCents    Int      // order total in whole AMD (legacy column name)
  paymentLinkMode String @default("FULL_ONLY") // FULL_ONLY | SPLIT_ENABLED (admin-controlled link options)
  paymentType   String   // FULL | SPLIT | UNSET (UNSET until client chooses)
  paidCents     Int      @default(0) // paid total in whole AMD (Stripe minor → /100)
  status        String   @default("PENDING") // PENDING | PAYMENT_PROCESSING | PAID
  /// Set when the payment link email was successfully sent (admin action).
  paymentLinkSentAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

/// Site-wide managed images (R2 object keys; public URL via R2_PUBLIC_URL).
/// Neon-ում սյուների անունները՝ sectionKey / slotId (ոչ թե groupKey / slotKey)։
model SiteMediaItem {
  id             String   @id @default(cuid())
  sectionKey     String
  /// Modeling slot id (e.g. hip_hop) or UUID for gallery rows — DB-ում GLOBAL UNIQUE։
  slotId         String   @unique
  sortOrder      Int      @default(0)
  r2ObjectKey    String?
  /// Modeling Specialization only — separate mobile asset; optional when desktop is set (falls back to desktop URL on site).
  r2ObjectKeyMobile String?
  legacySrc      String?
  alt            String?
  layoutMeta     Json?
  publicLabelKey String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([sectionKey, sortOrder])
}

/// Editable hero (power banner) title + body per landing slide — managed in Admin → Media Manager.
model PowerBannerCopy {
  bannerKey   String   @id
  title       String   @db.Text
  body        String   @db.Text
  /// Custom hero art (R2). When null, built-in desktop + mobile assets from the codebase are used.
  r2ObjectKey String?
  /// Focal point + zoom for custom hero art (`focusX`/`focusY` 0–100, `zoom` 1–3). Null when using built-in assets.
  heroImageLayout Json?
  updatedAt   DateTime @updatedAt
}

/// Modeling Specialization card title + rich body — Admin → Media Manager (matches hero sanitizer).
model ModelingSlotCopy {
  slotKey   String   @id
  title     String   @db.Text
  /// Optional title for viewports below `md`. Null/empty → use `title`.
  titleMobile String? @db.Text
  body      String   @db.Text
  /// Optional rich HTML for viewports below `md` (matches image mobile breakpoint). Null/empty → use `body`.
  bodyMobile String? @db.Text
  /// Admin Media Manager — title + body overlay positions/sizes for md+ (percent of padded frame).
  textLayoutDesktop Json?
  /// Admin Media Manager — same for viewports below `md`.
  textLayoutMobile Json?
  updatedAt DateTime @updatedAt
}

/// Manufacturing Intelligence section — homepage title, optional rich intro, optional custom right-column image.
/// Single row: application id `singleton`.
model ManufacturingIntelligenceCopy {
  id        String   @id
  title     String   @db.Text
  body      String   @db.Text
  r2ObjectKey String?
  heroImageLayout Json?
  updatedAt DateTime @updatedAt
}

/// Per-row Manufacturing Intelligence accordion — title, rich body, optional detail image (R2).
/// `itemKey` matches `MANUFACTURING_SPECIALIZATION_IDS` in application code.
model ManufacturingSpecializationItemCopy {
  itemKey     String   @id
  title       String   @db.Text
  body        String   @db.Text
  r2ObjectKey String?
  heroImageLayout Json?
  updatedAt   DateTime @updatedAt
}

/// Founder & Lead CAD Engineer section — name, rich bio, optional photo (R2).
/// Single row: application id `singleton`.
model FounderSectionCopy {
  id              String   @id
  name            String   @db.Text
  body            String   @db.Text
  r2ObjectKey     String?
  heroImageLayout Json?
  updatedAt       DateTime @updatedAt
}

/// Our Engineering Process section copy — section title and per-step text content.
/// Single row: application id `singleton`.
model EngineeringProcessCopy {
  id               String   @id
  sectionTitle     String   @db.Text
  step1Title       String   @db.Text
  step1Subtitle    String   @db.Text
  step1Description String   @db.Text
  step2Title       String   @db.Text
  step2Subtitle    String   @db.Text
  step2Description String   @db.Text
  step3Title       String   @db.Text
  step3Subtitle    String   @db.Text
  step3Description String   @db.Text
  step4Title       String   @db.Text
  step4Subtitle    String   @db.Text
  step4Description String   @db.Text
  step5Title       String   @db.Text
  step5Subtitle    String   @db.Text
  step5Description String   @db.Text
  updatedAt        DateTime @updatedAt
}
