# Goldcrest 3D — env (օրինակ)
# Պատճենի՛ր .env և լրացրու՛ իրական արժեքներով։ Ոչ մի գաղտնաբառ կոդում մի դնի՛ր։

# ——— Neon PostgreSQL ———
# Neon Dashboard → Connection string: pooled (Runtime) և direct (Migrations)
# Pooled — Vercel / Next.js runtime (host-ը ...-pooler....neon.tech)
DATABASE_URL="postgresql://USER:PASSWORD@HOST-POOLER.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
# Direct — միայն Prisma migrate (host-ը առանց -pooler)
DIRECT_URL="postgresql://USER:PASSWORD@HOST-DIRECT.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# ——— Auth.js (admin panel) ———
# Գեներացնել: openssl rand -base64 32
AUTH_SECRET=""
# Dev: http://localhost:3000 | Prod: https://yourdomain.com
AUTH_URL="http://localhost:3000"

# ——— Cloudflare R2 (quote attachments, order product images) ———
# Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
# Public bucket URL (custom domain or R2 dev URL)
R2_PUBLIC_URL=""

# ——— Resend (reply to leads, payment link email) ———
# resend.com → API Keys
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@yourdomain.com"

# ——— Stripe (payment links — Full / 50-50) ———
# stripe.com → Developers → API keys
STRIPE_SECRET_KEY=""
# Webhook signing secret (stripe listen --forward-to ...)
STRIPE_WEBHOOK_SECRET=""
