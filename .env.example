# Goldcrest 3D — env (լոկալ)
# Նույն կառուցվածքը ինչ .env.example — լրացրու՛ իրական արժեքներով։

# ——— Neon PostgreSQL ———
# Neon Dashboard → Connection string: pooled (Runtime) և direct (Migrations)
# Pooled — Next.js runtime (host-ը ...-pooler....neon.tech)
# sslmode=verify-full — Neon-ում TLS + host verify; pg v8-ի require/prefer warning չի տալիս
DATABASE_URL="postgresql://USER:PASSWORD@HOST-POOLER.neon.tech/DBNAME?sslmode=verify-full&channel_binding=require"
# Direct — միայն Prisma migrate (host-ը առանց -pooler)
DIRECT_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=verify-full&channel_binding=require"

# ——— Auth.js (admin panel) ———
# Գեներացնել: openssl rand -base64 32
AUTH_SECRET=""
# Dev: http://localhost:3000 | Prod: https://yourdomain.com
AUTH_URL="http://localhost:3000"

# ——— Cloudflare R2 (quote attachments, order product images) ———
# R2 → Manage R2 API Tokens → Create; endpoint = https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
# Bucket → Settings → Public access: Public Development URL կամ custom domain
R2_PUBLIC_URL=""

# ——— Resend (reply to leads, payment link email) ———
# resend.com → API Keys. Domains → add/verify SPF+DKIM, then use an address on that domain.
RESEND_API_KEY=""
# Plain email or full header: "Display Name <addr@verified.domain>"
RESEND_FROM_EMAIL="GoldCrest <noreply@mail.yourdomain.com>"
# Customer Reply-To (comma-separated). "Reply" in the client uses these; if empty, defaults to info@goldcrest3d.com.
RESEND_REPLY_TO_EMAILS="info@goldcrest3d.com"
# Optional: "Visit our website" link in lead-reply emails. If unset, uses AUTH_URL / VERCEL_URL.
EMAIL_WEBSITE_URL="https://goldcrest3d.com"
# Նոր հայտի ծանուցում ադմինին (դատարկ = չուղարկել); նույն Resend-ով է ուղարկվում
ADMIN_NOTIFY_EMAIL=""
# Վճարման հղման absolute URL — AUTH_URL (տե՛ս Auth բաժինը վերևում)

# ——— Stripe (payment links — Full / 50-50) ———
# stripe.com → Developers → API keys. Empty = checkout uses simulated payment UI (same as PAYMENT_MOCK_MODE).
STRIPE_SECRET_KEY=""
# ISO 4217 lowercase code for Checkout (must match your Stripe account settlement currency).
STRIPE_CHECKOUT_CURRENCY_ISO=""
# Webhook signing secret (stripe listen --forward-to ...)
STRIPE_WEBHOOK_SECRET=""

# ——— Dev-only mock payments (no real charges; no Stripe API for checkout) ———
# true = simulated checkout at /order/[token]/mock-payment. false = use Stripe.
# Never enable in production for real customers.
PAYMENT_MOCK_MODE="false"
