# Goldcrest 3D — env փոփոխականներ (օրինակ)
# Պատճենի՛ր .env և լրացրու՛ իրական արժեքներով։ Ոչ մի գաղտնաբառ կոդում մի դնի՛ր։

# ——— Neon PostgreSQL ———
# Connection string (pooled) — Vercel / runtime
DATABASE_URL="postgresql://user:password@host.neon.tech/neondb?sslmode=require"
# Direct (migrations) — Prisma migrate
DIRECT_URL="postgresql://user:password@host.neon.tech/neondb?sslmode=require"

# ——— Auth.js (admin) ———
# openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# ——— Cloudflare R2 (quote attachments, order images) ———
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# ——— Resend (reply to leads, payment link email) ———
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@example.com"

# ——— Stripe (payment links — Full / 50-50) ———
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
